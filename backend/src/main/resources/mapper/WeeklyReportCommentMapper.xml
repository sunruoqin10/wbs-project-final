<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wbs.project.mapper.WeeklyReportCommentMapper">

    <resultMap id="BaseResultMap" type="com.wbs.project.entity.WeeklyReportComment">
        <id column="id" property="id"/>
        <result column="report_id" property="reportId"/>
        <result column="user_id" property="userId"/>
        <result column="content" property="content"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, report_id, user_id, content, created_at
    </sql>

    <select id="selectByReportId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_weekly_report_comment
        WHERE report_id = #{reportId}
        ORDER BY created_at DESC
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_weekly_report_comment
        WHERE id = #{id}
    </select>

    <insert id="insert">
        INSERT INTO sys_weekly_report_comment (id, report_id, user_id, content, created_at)
        VALUES (#{id}, #{reportId}, #{userId}, #{content}, #{createdAt})
    </insert>

    <delete id="deleteById">
        DELETE FROM sys_weekly_report_comment WHERE id = #{id}
    </delete>

    <delete id="deleteByReportId">
        DELETE FROM sys_weekly_report_comment WHERE report_id = #{reportId}
    </delete>

    <select id="countByReportId" resultType="int">
        SELECT COUNT(*) FROM sys_weekly_report_comment WHERE report_id = #{reportId}
    </select>
</mapper>
