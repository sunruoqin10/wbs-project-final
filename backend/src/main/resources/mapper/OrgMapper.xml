<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wbs.project.mapper.OrgMapper">

    <resultMap id="OrgNodeMap" type="com.wbs.project.dto.OrgNode">
        <result column="code"        property="code"/>
        <result column="name"        property="name"/>
        <result column="company_cd"  property="companyCd"/>
        <result column="parent_code" property="parentCode"/>
        <result column="level_num"   property="level"/>
    </resultMap>

    <select id="selectAllOrgNodes" resultMap="OrgNodeMap">
        SELECT
            ORG_CD       AS code,
            ORG_NAM      AS name,
            COMPANY_CD   AS company_cd,
            PRNT_ORG_CD  AS parent_code,
            CAST(ORG_LVL_NUM AS UNSIGNED) AS level_num
        FROM mdm_if_or_a
        WHERE ORG_CD IS NOT NULL AND ORG_CD != ''
        ORDER BY CAST(ORG_LVL_NUM AS UNSIGNED), ORG_CD
    </select>

</mapper>
